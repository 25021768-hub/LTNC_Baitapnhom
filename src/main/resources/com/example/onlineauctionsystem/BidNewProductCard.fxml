<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<GridPane xmlns="http://javafx.com/javafx/17.0.12"
          xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="com.example.onlineauctionsystem.controller.common.BidNewProductCardController"
          hgap="15.0" vgap="0.0"
          maxWidth="450.0" minWidth="450.0" prefWidth="450.0"
          maxHeight="135.0" minHeight="135.0" prefHeight="135.0"
          style="-fx-background-color: #ffffff;
                 -fx-background-radius: 16;
                 -fx-border-radius: 16;
                 -fx-border-color: #eaeaea;
                 -fx-border-width: 1;
                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 10, 0, 0, 4);">

    <columnConstraints>
        <ColumnConstraints minWidth="100.0" maxWidth="100.0" prefWidth="100.0" hgrow="NEVER" />
        <ColumnConstraints minWidth="220.0" prefWidth="220.0" hgrow="ALWAYS" />
        <ColumnConstraints minWidth="95.0" maxWidth="95.0" prefWidth="95.0" hgrow="NEVER" />
    </columnConstraints>

    <rowConstraints>
        <RowConstraints minHeight="115.0" prefHeight="115.0" vgrow="ALWAYS" />
    </rowConstraints>

    <padding>
        <Insets bottom="10.0" left="12.0" right="12.0" top="10.0" />
    </padding>

    <StackPane style="-fx-background-radius: 12;
                      -fx-border-radius: 12;
                      -fx-background-color: #fdfdfd;
                      -fx-border-color: #eaeaea;
                      -fx-border-width: 1;"
               GridPane.columnIndex="0">
        <children>
            <ImageView fx:id="imgProduct"
                       fitHeight="85.0" fitWidth="85.0"
                       pickOnBounds="true" preserveRatio="true">
                <StackPane.margin>
                    <Insets bottom="2.0" left="2.0" right="2.0" top="2.0" />
                </StackPane.margin>
            </ImageView>
        </children>
    </StackPane>

    <GridPane GridPane.columnIndex="1" vgap="4.0">
        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="42.0" maxHeight="42.0" prefHeight="42.0" vgrow="NEVER" />
            <RowConstraints minHeight="24.0" maxHeight="24.0" prefHeight="24.0" vgrow="NEVER" />
            <RowConstraints minHeight="24.0" maxHeight="24.0" prefHeight="24.0" vgrow="NEVER" />
        </rowConstraints>
        <children>
            <Label fx:id="lblName" text="Tên sản phẩm..." wrapText="true" alignment="TOP_LEFT" GridPane.rowIndex="0">
                <font>
                    <Font name="System Bold" size="14.5" />
                </font>
            </Label>

            <HBox alignment="CENTER_LEFT" spacing="4.0" GridPane.rowIndex="1">
                <children>
                    <Label text="Giá hiện tại:" textFill="#555555">
                        <font><Font size="13.0" /></font>
                    </Label>
                    <Label fx:id="lblPrice" text="---" textFill="#1357b7">
                        <font><Font name="System Bold" size="13.5" /></font>
                    </Label>
                </children>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="4.0" GridPane.rowIndex="2">
                <children>
                    <Label text="Thời gian còn:" textFill="#e67e22">
                        <font><Font size="12.5" /></font>
                    </Label>
                    <Label fx:id="lblTime" text="---" textFill="#e67e22">
                        <font><Font name="System Bold Italic" size="12.5" /></font>
                    </Label>
                </children>
            </HBox>
        </children>
        <GridPane.margin>
            <Insets top="2.0" bottom="2.0" />
        </GridPane.margin>
    </GridPane>

    <VBox GridPane.columnIndex="2" alignment="CENTER">
        <children>
            <Button fx:id="btnBid"
                    id="btnBidCard"
                    mnemonicParsing="false"
                    onAction="#onBid"
                    text="Đấu giá"
                    textAlignment="CENTER"
                    textFill="WHITE"
                    prefWidth="85.0"
                    prefHeight="32.0"
                    style="-fx-background-color: linear-gradient(to bottom right, #0099cc 0%, #004488 100%);
                           -fx-background-radius: 20;
                           -fx-font-weight: bold;
                           -fx-font-size: 13.0;
                           -fx-cursor: hand;">
                <cursor>
                    <Cursor fx:constant="HAND" />
                </cursor>
            </Button>
        </children>
    </VBox>

</GridPane>