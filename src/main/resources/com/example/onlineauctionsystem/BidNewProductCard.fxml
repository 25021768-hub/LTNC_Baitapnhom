<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>

<GridPane hgap="15.0" maxHeight="135.0" maxWidth="1.7976931348623157E308" minHeight="135.0" minWidth="320.0" prefHeight="135.0" style="-fx-background-color: #ffffff;                  -fx-background-radius: 16;                  -fx-border-radius: 16;                  -fx-border-color: #eaeaea;                  -fx-border-width: 1;                  -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 10, 0, 0, 4);" vgap="0.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.onlineauctionsystem.controller.common.BidNewProductCardController">

    <columnConstraints>
        <ColumnConstraints hgrow="NEVER" maxWidth="100.0" minWidth="100.0" prefWidth="100.0" />
        <ColumnConstraints hgrow="ALWAYS" minWidth="100.0" />
        <ColumnConstraints hgrow="NEVER" maxWidth="95.0" minWidth="95.0" prefWidth="95.0" />
    </columnConstraints>

    <rowConstraints>
        <RowConstraints minHeight="115.0" prefHeight="115.0" vgrow="ALWAYS" />
    </rowConstraints>

    <padding>
        <Insets bottom="10.0" left="12.0" right="12.0" top="10.0" />
    </padding>

    <StackPane style="-fx-background-radius: 12;                       -fx-border-radius: 12;                       -fx-background-color: #fdfdfd;                       -fx-border-color: #eaeaea;                       -fx-border-width: 1;" GridPane.columnIndex="0">
        <children>
            <ImageView fx:id="imgProduct" fitHeight="85.0" fitWidth="85.0" pickOnBounds="true" preserveRatio="true">
                <StackPane.margin>
                    <Insets bottom="2.0" left="2.0" right="2.0" top="2.0" />
                </StackPane.margin>
            </ImageView>
        </children>
      <effect>
         <DropShadow>
            <color>
               <Color red="0.5372549295425415" green="0.5372549295425415" blue="0.5372549295425415" />
            </color>
         </DropShadow>
      </effect>
    </StackPane>

    <GridPane vgap="4.0" GridPane.columnIndex="1">
        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints maxHeight="42.0" minHeight="42.0" prefHeight="42.0" vgrow="NEVER" />
            <RowConstraints maxHeight="24.0" minHeight="24.0" prefHeight="24.0" vgrow="NEVER" />
            <RowConstraints maxHeight="24.0" minHeight="24.0" prefHeight="24.0" vgrow="NEVER" />
        </rowConstraints>
        <children>
            <Label fx:id="lblName" alignment="TOP_LEFT" text="Tên sản phẩm..." wrapText="true" GridPane.rowIndex="0">
                <font>
                    <Font name="System Bold" size="14.5" />
                </font>
            </Label>

            <HBox alignment="CENTER_LEFT" spacing="4.0" GridPane.rowIndex="1">
                <children>
                    <Label text="Giá hiện tại:" textFill="#555555">
                        <font><Font size="13.0" /></font>
                    </Label>
                    <Label fx:id="lblPrice" text="---" textFill="#1357b7">
                        <font><Font name="System Bold" size="13.5" /></font>
                    </Label>
                </children>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="4.0" GridPane.rowIndex="2">
                <children>
                    <Label text="Thời gian còn:" textFill="#e67e22">
                        <font><Font size="12.5" /></font>
                    </Label>
                    <Label fx:id="lblTime" text="---" textFill="#e67e22">
                        <font><Font name="System Bold Italic" size="12.5" /></font>
                    </Label>
                </children>
            </HBox>
        </children>
        <GridPane.margin>
            <Insets bottom="2.0" top="2.0" />
        </GridPane.margin>
    </GridPane>

    <VBox alignment="CENTER" GridPane.columnIndex="2">
        <children>
            <Button id="btnBidCard" fx:id="btnBid" mnemonicParsing="false" onAction="#onBid" prefHeight="5.0" prefWidth="72.0" style="-fx-background-color: linear-gradient(to bottom right, #0099cc 0%, #004488 100%);                            -fx-background-radius: 20;                            -fx-font-weight: bold;                            -fx-font-size: 13.0;                            -fx-cursor: hand;" text="Đấu giá" textAlignment="CENTER" textFill="WHITE">
                <cursor>
                    <Cursor fx:constant="HAND" />
                </cursor>
            </Button>
        </children>
    </VBox>

</GridPane>
