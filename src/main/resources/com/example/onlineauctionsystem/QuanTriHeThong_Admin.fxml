<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>

<VBox fx:controller="com.example.onlineauctionsystem.controller.admin.AdminUserController"
      maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
      minHeight="700.0" minWidth="900.0"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <HBox minHeight="78.0" prefHeight="78.0" spacing="10.0"
            style="-fx-background-color: linear-gradient(to bottom left, #0099cc 0%, #004488 40%, #001a33 100%);">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="78.0" HBox.hgrow="NEVER">
               <padding><Insets left="20.0" /></padding>
               <children>
                  <ImageView fitHeight="60.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true">
                     <HBox.margin><Insets /></HBox.margin>
                     <image>
                        <Image url="@../../../Kho_anh/vnu-uet-removebg-preview.png" />
                     </image>
                  </ImageView>
                  <Label text="ĐẤU GIÁ UET" textFill="WHITE">
                     <font><Font name="System Bold" size="20.0" /></font>
                     <HBox.margin><Insets left="3.0" /></HBox.margin>
                  </Label>
               </children>
            </HBox>
            <HBox alignment="CENTER" prefHeight="78.0" spacing="10.0" HBox.hgrow="ALWAYS">
               <children>
                  <VBox alignment="CENTER" prefWidth="117.0">
                     <children>
                        <Button onAction="#onAdminSystem" contentDisplay="TOP" mnemonicParsing="false" prefHeight="75.0" prefWidth="161.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-border-width: 2; -fx-border-color: white;" text="Quản trị hệ thống">
                           <font><Font size="10.0" /></font>
                           <graphic>
                              <ImageView fitHeight="15.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true">
                                 <image><Image url="@../../../Kho_anh/QuanTriHeThong.png" /></image>
                              </ImageView>
                           </graphic>
                           <effect>
                              <DropShadow>
                                 <color><Color red="1.0" green="1.0" blue="1.0" /></color>
                              </DropShadow>
                           </effect>
                        </Button>
                     </children>
                  </VBox>
                  <Button onAction="#onProductPending" contentDisplay="TOP" mnemonicParsing="false" prefHeight="92.0" prefWidth="118.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="Phê duyệt sản phẩm">
                     <font><Font size="10.0" /></font>
                     <graphic>
                        <ImageView fitHeight="15.0" fitWidth="15.0" pickOnBounds="true" preserveRatio="true">
                           <image><Image url="@../../../Kho_anh/PheDuyetSanPham.png" /></image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <VBox alignment="CENTER" prefWidth="117.0">
                     <children>
                        <Button onAction="#onLogout" contentDisplay="TOP" mnemonicParsing="false" prefHeight="100.0" prefWidth="141.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="Đăng xuất">
                           <font><Font size="10.0" /></font>
                           <graphic>
                              <ImageView fitHeight="15.0" fitWidth="15.0" pickOnBounds="true" preserveRatio="true">
                                 <image><Image url="@../../../Kho_anh/logout.png" /></image>
                              </ImageView>
                           </graphic>
                        </Button>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </HBox>

      <VBox spacing="10.0" VBox.vgrow="ALWAYS">
         <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
         <children>
            <Label prefHeight="40.0" maxWidth="1.7976931348623157E308" text="Quản lý danh sách người dùng">
               <font><Font name="System Bold" size="20.0" /></font>
            </Label>

            <VBox VBox.vgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-radius: 10;">
               <effect>
                  <DropShadow>
                     <color><Color red="0.5372549295425415" green="0.5372549295425415" blue="0.5372549295425415" /></color>
                  </DropShadow>
               </effect>
               <children>
                  <GridPane minHeight="45.0" prefHeight="45.0"
                            style="-fx-background-radius: 10 10 0 0; -fx-border-radius: 10 10 0 0;">
                     <columnConstraints>
                        <ColumnConstraints hgrow="NEVER" minWidth="90.0" prefWidth="90.0" maxWidth="90.0" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="80.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="120.0" prefWidth="150.0" maxWidth="150.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="80.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="80.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="NEVER" minWidth="110.0" prefWidth="110.0" maxWidth="110.0" />
                        <ColumnConstraints hgrow="NEVER" minWidth="110.0" prefWidth="110.0" maxWidth="110.0" />
                     </columnConstraints>
                     <rowConstraints>
                        <RowConstraints minHeight="45.0" prefHeight="45.0" maxHeight="45.0" vgrow="SOMETIMES" />
                     </rowConstraints>
                     <children>
                        <Label prefHeight="18.0" text="Avatar">
                           <GridPane.margin><Insets left="5.0" /></GridPane.margin>
                           <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <Label prefHeight="18.0" text="Họ và tên" GridPane.columnIndex="1">
                           <GridPane.margin><Insets left="5.0" /></GridPane.margin>
                           <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <Label prefHeight="18.0" text="Email" GridPane.columnIndex="2">
                           <GridPane.margin><Insets left="5.0" /></GridPane.margin>
                           <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <Label prefHeight="18.0" text="Điện thoại" GridPane.columnIndex="3">
                           <GridPane.margin><Insets left="5.0" /></GridPane.margin>
                           <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <Label prefHeight="18.0" text="CCCD" GridPane.columnIndex="4">
                           <GridPane.margin><Insets left="5.0" /></GridPane.margin>
                           <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <Label prefHeight="18.0" text="Chức năng" GridPane.columnIndex="5">
                           <GridPane.margin><Insets left="5.0" /></GridPane.margin>
                           <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <Label prefHeight="18.0" text="Trạng thái" GridPane.columnIndex="6">
                           <GridPane.margin><Insets left="5.0" /></GridPane.margin>
                           <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                     </children>
                  </GridPane>

                  <ScrollPane hbarPolicy="NEVER" fitToWidth="true" VBox.vgrow="ALWAYS">
                     <content>
                        <VBox fx:id="userListContainer" spacing="5.0">
                           <padding><Insets top="5.0" /></padding>
                        </VBox>
                     </content>
                  </ScrollPane>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</VBox>
