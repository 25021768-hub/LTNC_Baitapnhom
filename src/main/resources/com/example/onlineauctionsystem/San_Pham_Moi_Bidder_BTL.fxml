<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.onlineauctionsystem.controller.bidder.BidderController"
      prefHeight="700.0"
      prefWidth="900.0"
      minHeight="500.0"
      minWidth="600.0">

   <children>
      <HBox spacing="10.0"
            style="-fx-background-color: linear-gradient(to bottom left, #0099cc 0%, #004488 40%, #001a33 100%);"
            minHeight="78.0"
            prefHeight="78.0">

         <HBox alignment="CENTER"
               prefHeight="78.0"
               prefWidth="286.0"
               HBox.hgrow="NEVER">
            <children>
               <ImageView fitHeight="60.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true">
                  <HBox.margin>
                     <Insets />
                  </HBox.margin>
                  <image>
                     <Image url="@../../../Kho_anh/vnu-uet-removebg-preview.png" />
                  </image>
               </ImageView>
               <Label text="ĐẤU GIÁ UET" textFill="WHITE">
                  <font>
                     <Font name="System Bold" size="20.0" />
                  </font>
                  <HBox.margin>
                     <Insets left="3.0" />
                  </HBox.margin>
               </Label>
            </children>
         </HBox>

         <Region HBox.hgrow="ALWAYS" />

         <HBox alignment="CENTER"
               prefHeight="74.0"
               spacing="10.0"
               HBox.hgrow="NEVER">
            <padding>
               <Insets right="10.0" />
            </padding>
            <children>
               <Button contentDisplay="TOP"
                       mnemonicParsing="false"
                       onAction="#onMyProducts"
                       prefHeight="106.0"
                       prefWidth="114.0"
                       style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-border-color: white; -fx-border-width: 2;"
                       text="Sản phẩm mới">
                  <font>
                     <Font size="10.0" />
                  </font>
                  <graphic>
                     <ImageView fitHeight="15.0" fitWidth="15.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                           <Image url="@../../../Kho_anh/gift.png" />
                        </image>
                     </ImageView>
                  </graphic>
                  <effect>
                     <DropShadow>
                        <color>
                           <Color red="1.0" green="1.0" blue="1.0" />
                        </color>
                     </DropShadow>
                  </effect>
               </Button>

               <Button contentDisplay="TOP"
                       mnemonicParsing="false"
                       onAction="#onHistory"
                       prefHeight="102.0"
                       prefWidth="118.0"
                       style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;"
                       text="Lịch sử đấu giá">
                  <font>
                     <Font size="10.0" />
                  </font>
                  <graphic>
                     <ImageView fitHeight="15.0" fitWidth="15.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                           <Image url="@../../../Kho_anh/history.png" />
                        </image>
                     </ImageView>
                  </graphic>
               </Button>

               <Button contentDisplay="TOP"
                       mnemonicParsing="false"
                       onAction="#onManage"
                       prefHeight="86.0"
                       prefWidth="114.0"
                       style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;"
                       text=" Đấu giá đang thắng">
                  <font>
                     <Font size="10.0" />
                  </font>
                  <graphic>
                     <ImageView fitHeight="15.0" fitWidth="15.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                           <Image url="@../../../Kho_anh/trophy.png" />
                        </image>
                     </ImageView>
                  </graphic>
               </Button>

               <Button contentDisplay="TOP"
                       mnemonicParsing="false"
                       onAction="#onAccount"
                       prefHeight="92.0"
                       prefWidth="114.0"
                       style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;"
                       text="Tài khoản">
                  <font>
                     <Font size="10.0" />
                  </font>
                  <graphic>
                     <ImageView fitHeight="15.0" fitWidth="15.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                           <Image url="@../../../Kho_anh/user.png" />
                        </image>
                     </ImageView>
                  </graphic>
               </Button>

               <Button contentDisplay="TOP"
                       mnemonicParsing="false"
                       onAction="#onLogout"
                       prefHeight="103.0"
                       prefWidth="134.0"
                       style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;"
                       text="Đăng xuất">
                  <font>
                     <Font size="10.0" />
                  </font>
                  <graphic>
                     <ImageView fitHeight="15.0" fitWidth="15.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                           <Image url="@../../../Kho_anh/logout.png" />
                        </image>
                     </ImageView>
                  </graphic>
               </Button>
            </children>
         </HBox>

      </HBox>

      <ScrollPane fitToWidth="true"
                  hbarPolicy="NEVER"
                  vbarPolicy="AS_NEEDED"
                  VBox.vgrow="ALWAYS">
         <content>
            <VBox spacing="25.0"
                  style="-fx-background-color: white;"
                  VBox.vgrow="ALWAYS">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <children>
                  <StackPane>
                     <children>
                        <TextField fx:id="txtSearch"
                                   promptText="Tìm kiếm sản phẩm..."
                                   onKeyReleased="#onSearch"
                                   maxWidth="Infinity"
                                   style="-fx-background-radius: 20; -fx-text-fill: white;
                                          -fx-prompt-text-fill: #cccccc; -fx-padding: 5 15 5 35;
                                          -fx-background-color: linear-gradient(to bottom left, #0099cc 0%, #004488 40%, #001a33 80%);" />
                        <ImageView fitHeight="15.0" fitWidth="25.0"
                                   pickOnBounds="true" preserveRatio="true"
                                   StackPane.alignment="CENTER_LEFT">
                           <image><Image url="@../../../Kho_anh/Kinh_lup.png" /></image>
                           <StackPane.margin><Insets left="10.0" top="3.0" /></StackPane.margin>
                        </ImageView>
                     </children>
                  </StackPane>

                  <GridPane fx:id="productContainer"
                            hgap="20.0" vgap="20.0">
                     <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" percentWidth="50.0" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" percentWidth="50.0" />
                     </columnConstraints>
                  </GridPane>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </children>
</VBox>
