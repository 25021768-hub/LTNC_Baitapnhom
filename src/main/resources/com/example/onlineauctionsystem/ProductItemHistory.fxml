<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>

<GridPane prefHeight="100.0" prefWidth="780.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.onlineauctionsystem.controller.common.ProductItemHistoryController">
    <columnConstraints>
        <ColumnConstraints hgrow="SOMETIMES" maxWidth="110.0" minWidth="110.0" prefWidth="110.0" />
        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        <ColumnConstraints hgrow="SOMETIMES" maxWidth="115.0" minWidth="115.0" prefWidth="115.0" />
        <ColumnConstraints hgrow="SOMETIMES" maxWidth="150.0" minWidth="150.0" prefWidth="150.0" />
        <ColumnConstraints hgrow="SOMETIMES" maxWidth="115.0" minWidth="115.0" prefWidth="115.0" />
        <ColumnConstraints hgrow="SOMETIMES" maxWidth="120.0" minWidth="120.0" prefWidth="120.0" />
    </columnConstraints>
    <rowConstraints>
        <RowConstraints maxHeight="100.0" minHeight="100.0" prefHeight="100.0" vgrow="SOMETIMES" />
    </rowConstraints>
    <children>
        <StackPane prefHeight="90.0" prefWidth="90.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-radius: 10;">
            <GridPane.margin>
                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
            </GridPane.margin>
            <effect>
                <DropShadow offsetY="4.0">
                    <color>
                        <Color red="0.5368421077728271" green="0.5368421077728271" blue="0.5368421077728271" />
                    </color>
                </DropShadow>
            </effect>
            <children>
                <ImageView fx:id="imgProduct" fitHeight="80.0" fitWidth="80.0" pickOnBounds="true" preserveRatio="true">
                    <StackPane.margin>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                    </StackPane.margin>
                </ImageView>
            </children>
        </StackPane>
        <Label fx:id="lblName" prefHeight="110.0" prefWidth="131.0" text="Bộ Pc" wrapText="true" GridPane.columnIndex="1">
            <font>
                <Font size="14.0" />
            </font>
            <GridPane.margin>
                <Insets left="5.0" />
            </GridPane.margin>
        </Label>
        <Label fx:id="lblCurrentPrice" prefHeight="105.0" prefWidth="115.0" text="20.000.000đ" wrapText="true" GridPane.columnIndex="2">
            <font>
                <Font size="14.0" />
            </font>
            <padding>
                <Insets left="5.0" />
            </padding>
        </Label>
        <Label fx:id="lblcurrentBidder" prefHeight="100.0" prefWidth="151.0" text="Nguyễn Văn A" wrapText="true" GridPane.columnIndex="3">
            <font>
                <Font size="14.0" />
            </font>
            <padding>
                <Insets left="5.0" />
            </padding>
        </Label>
        <Label fx:id="lblsellDate" prefHeight="102.0" prefWidth="115.0" text="10/05/2026" wrapText="true" GridPane.columnIndex="4">
            <font>
                <Font size="14.0" />
            </font>
            <padding>
                <Insets left="5.0" />
            </padding>
        </Label>
        <Label fx:id="lblStatus" alignment="CENTER" prefHeight="29.0" prefWidth="94.0" style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-background-color: green;" text="Thành công" textFill="WHITE" GridPane.columnIndex="5">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
            <GridPane.margin>
                <Insets left="13.0" />
            </GridPane.margin>
        </Label>
    </children>
</GridPane>
