<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>

<VBox fx:controller="com.example.onlineauctionsystem.controller.seller.SellerManageController"
      maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
      minHeight="700.0" minWidth="900.0"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <HBox minHeight="78.0" prefHeight="78.0" spacing="10.0"
            style="-fx-background-color: linear-gradient(to bottom left, #0099cc 0%, #004488 40%, #001a33 100%);">
         <children>
            <HBox alignment="CENTER" prefHeight="78.0" prefWidth="286.0" HBox.hgrow="NEVER">
               <children>
                  <ImageView fitHeight="60.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true">
                     <HBox.margin><Insets /></HBox.margin>
                     <image>
                        <Image url="@../../../Kho_anh/vnu-uet-removebg-preview.png" />
                     </image>
                  </ImageView>
                  <Label text="ĐẤU GIÁ UET" textFill="WHITE">
                     <font><Font name="System Bold" size="20.0" /></font>
                     <HBox.margin><Insets left="3.0" /></HBox.margin>
                  </Label>
               </children>
            </HBox>
            <HBox alignment="CENTER" prefHeight="74.0" spacing="10.0" HBox.hgrow="ALWAYS">
               <children>
                  <VBox alignment="CENTER" prefWidth="117.0">
                     <children>
                        <Button contentDisplay="TOP" mnemonicParsing="false" onAction="#onMyProducts" prefHeight="75.0" prefWidth="161.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="Sản phẩm của tôi">
                           <font><Font size="10.0" /></font>
                           <graphic>
                              <ImageView fitHeight="15.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true">
                                 <image><Image url="@../../../Kho_anh/TuiSachKinhDoanh.png" /></image>
                              </ImageView>
                           </graphic>
                        </Button>
                     </children>
                  </VBox>
                  <VBox alignment="CENTER" prefWidth="117.0">
                     <children>
                        <Button contentDisplay="TOP" mnemonicParsing="false" onAction="#onHistory" prefHeight="92.0" prefWidth="118.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="Lịch sử hàng đã bán">
                           <font><Font size="10.0" /></font>
                           <graphic>
                              <ImageView fitHeight="15.0" fitWidth="15.0" pickOnBounds="true" preserveRatio="true">
                                 <image><Image url="@../../../Kho_anh/LichSuDaBan.png" /></image>
                              </ImageView>
                           </graphic>
                        </Button>
                     </children>
                  </VBox>
                  <VBox alignment="CENTER" prefWidth="117.0">
                     <children>
                        <Button contentDisplay="TOP" mnemonicParsing="false" onAction="#onManage" prefHeight="106.0" prefWidth="114.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-border-color: white; -fx-border-width: 2;" text="Quản lý đăng bán">
                           <font><Font size="10.0" /></font>
                           <graphic>
                              <ImageView fitHeight="15.0" fitWidth="15.0" pickOnBounds="true" preserveRatio="true">
                                 <image><Image url="@../../../Kho_anh/QuanLyDangBan.png" /></image>
                              </ImageView>
                           </graphic>
                           <effect>
                              <DropShadow>
                                 <color><Color red="1.0" green="1.0" blue="1.0" /></color>
                              </DropShadow>
                           </effect>
                        </Button>
                     </children>
                  </VBox>
                  <VBox alignment="CENTER" prefWidth="117.0">
                     <children>
                        <Button contentDisplay="TOP" mnemonicParsing="false" onAction="#onAccount" prefHeight="105.0" prefWidth="114.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="Tài khoản">
                           <font><Font size="10.0" /></font>
                           <graphic>
                              <ImageView fitHeight="15.0" fitWidth="15.0" pickOnBounds="true" preserveRatio="true">
                                 <image><Image url="@../../../Kho_anh/user.png" /></image>
                              </ImageView>
                           </graphic>
                        </Button>
                     </children>
                  </VBox>
                  <VBox alignment="CENTER" prefWidth="117.0">
                     <children>
                        <Button contentDisplay="TOP" mnemonicParsing="false" onAction="#onLogout" prefHeight="100.0" prefWidth="141.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="Đăng xuất">
                           <font><Font size="10.0" /></font>
                           <graphic>
                              <ImageView fitHeight="15.0" fitWidth="15.0" pickOnBounds="true" preserveRatio="true">
                                 <image><Image url="@../../../Kho_anh/logout.png" /></image>
                              </ImageView>
                           </graphic>
                        </Button>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </HBox>

      <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
         <content>
            <VBox alignment="TOP_LEFT" spacing="25.0">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <children>
                  <Button fx:id="btnAddProduct"
                          mnemonicParsing="false"
                          onAction="#onAddProduct"
                          prefHeight="36.0" prefWidth="207.0"
                          style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: linear-gradient(to bottom left, #0099cc 0%, #004488 40%, #001a33 100%);"
                          text="[+] Đăng bán sản phẩm mới" textFill="#1365a4">
                     <font><Font name="System Bold" size="14.0" /></font>
                     <cursor><Cursor fx:constant="HAND" /></cursor>
                  </Button>

                  <Label text="SẢN PHẨM ĐANG CHỜ PHÊ DUYỆT">
                     <font><Font name="System Bold" size="20.0" /></font>
                  </Label>

                  <FlowPane fx:id="pendingContainer"
                            hgap="20.0" vgap="20.0"
                            maxWidth="1.7976931348623157E308" />
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </children>
</VBox>
