<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.ImageView?>
<GridPane fx:controller="com.example.onlineauctionsystem.controller.common.UserController"
          prefWidth="860.0"
          style="-fx-border-color: #e0e0e0;"
          xmlns="http://javafx.com/javafx/17.0.12"
          xmlns:fx="http://javafx.com/fxml/1">

    <rowConstraints>
        <RowConstraints minHeight="90.0" maxHeight="90.0" prefHeight="90.0" />
    </rowConstraints>

    <children>
        <!-- Avatar -->
        <StackPane maxHeight="85.0" maxWidth="85.0" minHeight="85.0" minWidth="85.0"
                   style="-fx-background-radius: 100; -fx-border-radius: 100;
                          -fx-border-color: #004488; -fx-border-width: 3;">
            <children>
                <ImageView fx:id="imgAvatar"
                           fitHeight="85.0" fitWidth="85.0"
                           pickOnBounds="true" preserveRatio="true" />
            </children>
        </StackPane>

        <!-- Họ tên -->
        <Label fx:id="lblFullName" text="---"
               prefHeight="95.0" prefWidth="134.0"
               wrapText="true" GridPane.columnIndex="1">
            <GridPane.margin><Insets left="5.0" /></GridPane.margin>
        </Label>

        <!-- Email -->
        <Label fx:id="lblEmail" text="---"
               prefHeight="90.0" prefWidth="151.0"
               wrapText="true" GridPane.columnIndex="2">
            <GridPane.margin><Insets left="5.0" /></GridPane.margin>
        </Label>

        <!-- Điện thoại -->
        <Label fx:id="lblPhone" text="---"
               prefHeight="90.0" prefWidth="151.0"
               wrapText="true" GridPane.columnIndex="3">
            <GridPane.margin><Insets left="5.0" /></GridPane.margin>
        </Label>

        <!-- CCCD -->
        <Label fx:id="lblIdCard" text="---"
               prefHeight="90.0" prefWidth="151.0"
               wrapText="true" GridPane.columnIndex="4">
            <GridPane.margin><Insets left="5.0" /></GridPane.margin>
        </Label>

        <!-- Chức năng (role) -->
        <Label fx:id="lblRole" text="---"
               prefHeight="107.0" prefWidth="110.0"
               GridPane.columnIndex="5">
            <GridPane.margin><Insets left="5.0" /></GridPane.margin>
        </Label>

        <!-- Nút khóa/mở -->
        <Button fx:id="btnToggle"
                mnemonicParsing="false"
                onAction="#onToggleLock"
                prefHeight="26.0" prefWidth="80.0"
                text="Khóa" textFill="WHITE"
                GridPane.columnIndex="6">
            <GridPane.margin><Insets left="5.0" /></GridPane.margin>
            <font><Font name="System Bold" size="12.0" /></font>
        </Button>
    </children>
</GridPane>