<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>

<VBox fx:controller="com.example.onlineauctionsystem.controller.seller.AddProductController"
      maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
      prefHeight="600.0" prefWidth="700.0" spacing="20.0"
      style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-radius: 15;"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
   <effect>
      <DropShadow>
         <color>
            <Color red="0.537" green="0.537" blue="0.537" />
         </color>
      </DropShadow>
   </effect>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>

      <!-- Tên sản phẩm -->
      <Label contentDisplay="RIGHT" prefHeight="27.0" prefWidth="661.0" text="Tên sản phẩm">
         <font><Font size="15.0" /></font>
         <graphic>
            <TextField fx:id="txtName"
                       prefHeight="27.0" prefWidth="554.0"
                       promptText="tên sản phẩm.."
                       style="-fx-background-color: white; -fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #1357b7;" />
         </graphic>
      </Label>

      <!-- Hình ảnh -->
      <Label text="Đăng tải hình ảnh sản phẩm">
         <font><Font size="15.0" /></font>
      </Label>

      <VBox alignment="CENTER" prefHeight="220.0" prefWidth="578.0"
            onDragOver="#onDragOver"
            onDragDropped="#onDragDropped"
            style="-fx-background-color: white; -fx-background-radius: 5; -fx-border-radius: 5;">
         <effect>
            <DropShadow>
               <color>
                  <Color red="0.537" green="0.537" blue="0.537" />
               </color>
            </DropShadow>
         </effect>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="131.0" prefWidth="620.0">
               <children>
                  <!-- Icon cửa sổ -->
                  <ImageView fitHeight="95.0" fitWidth="95.0" pickOnBounds="true" preserveRatio="true">
                     <image><Image url="@../../../Kho_anh/CuaSoDangBan.png" /></image>
                  </ImageView>

                  <!-- Text + nút chọn ảnh -->
                  <VBox alignment="CENTER_LEFT" prefHeight="83.0" prefWidth="307.0" spacing="8.0">
                     <padding><Insets left="10.0" /></padding>
                     <children>
                        <Label text="Kéo và thả hình ảnh vào đây">
                           <font><Font name="System Bold" size="20.0" /></font>
                        </Label>
                        <Label fx:id="lblImageName" text=""
                               style="-fx-text-fill: #555555; -fx-font-size: 12;" />
                        <Button text="Hoặc bấm để chọn ảnh"
                                onAction="#onChooseImage"
                                style="-fx-background-color: transparent; -fx-text-fill: #1357b7; -fx-cursor: hand; -fx-underline: true;
                                       -fx-padding: 0;" />
                     </children>
                  </VBox>

                  <!-- Preview ảnh -->
                  <StackPane maxHeight="135.0" maxWidth="135.0" minHeight="135.0" minWidth="135.0"
                             prefHeight="135.0" prefWidth="135.0"
                             style="-fx-background-color: #c4c4c4; -fx-background-radius: 5; -fx-border-radius: 5;">
                     <children>
                        <ImageView fx:id="imgPreview"
                                   fitHeight="135.0" fitWidth="135.0"
                                   pickOnBounds="true" preserveRatio="true" />
                     </children>
                  </StackPane>
               </children>
            </HBox>
         </children>
      </VBox>

      <!-- Thông số đấu giá -->
      <Label text="Thông số đấu giá">
         <font><Font name="System Bold" size="16.0" /></font>
      </Label>
      <HBox prefHeight="29.0" prefWidth="660.0" spacing="20.0">
         <children>
            <Label contentDisplay="RIGHT" prefHeight="30.0" prefWidth="254.0" text="Giá khởi điểm">
               <font><Font size="14.0" /></font>
               <graphic>
                  <TextField fx:id="txtInitialPrice"
                             prefHeight="28.0" prefWidth="159.0"
                             promptText="VD: 1000000"
                             style="-fx-background-color: white; -fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #1357b7;" />
               </graphic>
            </Label>
            <Label contentDisplay="RIGHT" prefHeight="30.0" prefWidth="254.0" text="Bước giá">
               <font><Font size="14.0" /></font>
               <graphic>
                  <TextField fx:id="txtBidIncrement"
                             prefHeight="28.0" prefWidth="159.0"
                             promptText="VD: 100000"
                             style="-fx-background-color: white; -fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #1357b7;" />
               </graphic>
            </Label>
         </children>
      </HBox>

      <!-- Thời gian -->
      <Label text="Thời gian đấu giá">
         <font><Font name="System Bold" size="16.0" /></font>
      </Label>
      <Label contentDisplay="RIGHT" prefHeight="30.0" prefWidth="413.0"
             text="Thời gian phiên đấu giá diễn ra ( giờ )">
         <font><Font size="14.0" /></font>
         <graphic>
            <TextField fx:id="txtDuration"
                       prefHeight="28.0" prefWidth="159.0"
                       promptText="VD: 24"
                       style="-fx-background-color: white; -fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #1357b7;" />
         </graphic>
      </Label>

      <!-- Thông báo lỗi -->
      <Label fx:id="lblError" text=""
             style="-fx-text-fill: red; -fx-font-size: 13;"
             wrapText="true" prefWidth="660.0" />

      <!-- Nút Hủy / Đăng bán -->
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="10.0">
         <children>
            <Button mnemonicParsing="false" onAction="#onCancel"
                    prefHeight="26.0" prefWidth="95.0"
                    style="-fx-background-radius: 20; -fx-border-radius: 20;"
                    text="Hủy">
               <cursor><Cursor fx:constant="HAND" /></cursor>
               <font><Font size="14.0" /></font>
            </Button>
            <Button mnemonicParsing="false" onAction="#onSubmit"
                    prefHeight="26.0" prefWidth="95.0"
                    style="-fx-background-radius: 20; -fx-border-radius: 20;
                           -fx-background-color: linear-gradient(to bottom left, #0099cc 0%, #004488 40%, #001a33 100%);"
                    text="Đăng bán" textFill="WHITE">
               <cursor><Cursor fx:constant="HAND" /></cursor>
               <font><Font size="14.0" /></font>
            </Button>
         </children>
      </HBox>

   </children>
</VBox>