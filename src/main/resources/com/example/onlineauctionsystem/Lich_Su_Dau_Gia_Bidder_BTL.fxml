<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>

<VBox fx:controller="com.example.onlineauctionsystem.controller.bidder.BidHistoryController"
      maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
      minHeight="700.0" minWidth="900.0"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <HBox maxHeight="78.0" minHeight="78.0" prefHeight="78.0" spacing="10.0"
            style="-fx-background-color: linear-gradient(to bottom left, #0099cc 0%, #004488 40%, #001a33 100%);">
         <children>
            <HBox alignment="CENTER" prefHeight="78.0" prefWidth="286.0" HBox.hgrow="NEVER">
               <children>
                  <ImageView fitHeight="60.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../../../Kho_anh/vnu-uet-removebg-preview.png" />
                     </image>
                  </ImageView>
                  <Label text="ĐẤU GIÁ UET" textFill="WHITE">
                     <font><Font name="System Bold" size="20.0" /></font>
                     <HBox.margin><Insets left="3.0" /></HBox.margin>
                  </Label>
               </children>
            </HBox>
            <HBox alignment="CENTER" prefHeight="74.0" spacing="10.0" HBox.hgrow="ALWAYS">
               <children>
                  <VBox alignment="CENTER" prefWidth="117.0">
                     <children>
                        <Button contentDisplay="TOP" mnemonicParsing="false" onAction="#onMyProducts" prefHeight="85.0" prefWidth="114.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="Sản phẩm mới">
                           <font><Font size="10.0" /></font>
                           <graphic>
                              <ImageView fitHeight="15.0" fitWidth="15.0" pickOnBounds="true" preserveRatio="true">
                                 <image><Image url="@../../../Kho_anh/gift.png" /></image>
                              </ImageView>
                           </graphic>
                        </Button>
                     </children>
                  </VBox>
                  <VBox alignment="CENTER" prefWidth="117.0">
                     <children>
                        <Button contentDisplay="TOP" mnemonicParsing="false" onAction="#onHistory" prefHeight="91.0" prefWidth="118.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-border-color: white; -fx-border-width: 2;" text="Lịch sử đấu giá">
                           <font><Font size="10.0" /></font>
                           <graphic>
                              <ImageView fitHeight="15.0" fitWidth="15.0" pickOnBounds="true" preserveRatio="true">
                                 <image><Image url="@../../../Kho_anh/history.png" /></image>
                              </ImageView>
                           </graphic>
                           <effect>
                              <DropShadow>
                                 <color><Color red="1.0" green="1.0" blue="1.0" /></color>
                              </DropShadow>
                           </effect>
                        </Button>
                     </children>
                  </VBox>
                  <VBox alignment="CENTER" prefWidth="117.0">
                     <children>
                        <Button contentDisplay="TOP" mnemonicParsing="false" onAction="#onManage" prefHeight="72.0" prefWidth="114.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="Bạn đang đấu giá">
                           <font><Font size="10.0" /></font>
                           <graphic>
                              <ImageView fitHeight="15.0" fitWidth="15.0" pickOnBounds="true" preserveRatio="true">
                                 <image><Image url="@../../../Kho_anh/trophy.png" /></image>
                              </ImageView>
                           </graphic>
                        </Button>
                     </children>
                  </VBox>
                  <VBox alignment="CENTER" prefWidth="117.0">
                     <children>
                        <Button contentDisplay="TOP" mnemonicParsing="false" onAction="#onAccount" prefHeight="77.0" prefWidth="114.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="Tài khoản">
                           <font><Font size="10.0" /></font>
                           <graphic>
                              <ImageView fx:id="onAccount" fitHeight="15.0" fitWidth="15.0" pickOnBounds="true" preserveRatio="true">
                                 <image><Image url="@../../../Kho_anh/user.png" /></image>
                              </ImageView>
                           </graphic>
                        </Button>
                     </children>
                  </VBox>
                  <VBox alignment="CENTER" prefWidth="117.0">
                     <children>
                        <Button contentDisplay="TOP" mnemonicParsing="false" onAction="#onLogout" prefHeight="122.0" prefWidth="145.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="Đăng xuất">
                           <font><Font size="10.0" /></font>
                           <graphic>
                              <ImageView fitHeight="15.0" fitWidth="15.0" pickOnBounds="true" preserveRatio="true">
                                 <image><Image url="@../../../Kho_anh/logout.png" /></image>
                              </ImageView>
                           </graphic>
                        </Button>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </HBox>

      <VBox spacing="15.0" VBox.vgrow="ALWAYS"
            style="-fx-background-radius: 15; -fx-background-color: white; -fx-border-radius: 15;">
         <VBox.margin><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></VBox.margin>
         <effect><DropShadow /></effect>
         <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>
         <children>
            <Label text="Lịch sử đấu giá cá nhân của bạn">
               <font><Font name="System Bold" size="24.0" /></font>
            </Label>

            <HBox alignment="CENTER_LEFT" minHeight="30.0" prefHeight="30.0" spacing="5.0">
               <children>
                  <Label text="Tên sản phẩm"><font><Font size="14.0" /></font></Label>
                  <TextField promptText="Tên sản phẩm muốn tìm"
                             style="-fx-background-color: white; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: black;"
                             HBox.hgrow="ALWAYS" />
                  <Label text="Trạng thái"><font><Font size="14.0" /></font></Label>
                  <ComboBox prefWidth="150.0" promptText="Lọc kết quả"
                            style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-background-color: white; -fx-border-color: black;">
                     <items>
                        <FXCollections fx:factory="observableArrayList">
                           <String fx:value="All" />
                           <String fx:value="Thắng" />
                           <String fx:value="Thua" />
                        </FXCollections>
                     </items>
                  </ComboBox>
               </children>
            </HBox>

            <VBox VBox.vgrow="ALWAYS" spacing="0.0"
                  style="-fx-background-radius: 15; -fx-border-radius: 15; -fx-background-color: white;">
               <effect><DropShadow /></effect>
               <children>
                  <GridPane alignment="CENTER" minHeight="30.0" prefHeight="30.0">
                     <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="150.0" prefWidth="200.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="80.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="80.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="90.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="75.0" prefWidth="100.0" />
                     </columnConstraints>
                     <rowConstraints>
                        <RowConstraints minHeight="30.0" prefHeight="30.0" vgrow="SOMETIMES" />
                     </rowConstraints>
                     <children>
                        <Label text="Tên vật phẩm" GridPane.columnIndex="0"><font><Font name="System Bold" size="15.0" /></font></Label>
                        <Label text="Mức giá bạn trả" GridPane.columnIndex="1"><font><Font name="System Bold" size="15.0" /></font></Label>
                        <Label text="Giá cuối cùng" GridPane.columnIndex="2"><font><Font name="System Bold" size="15.0" /></font></Label>
                        <Label text="Ngày kết thúc" GridPane.columnIndex="3"><font><Font name="System Bold" size="15.0" /></font></Label>
                        <Label text="Trạng thái" GridPane.columnIndex="4"><font><Font name="System Bold" size="15.0" /></font></Label>
                     </children>
                  </GridPane>

                  <ScrollPane hbarPolicy="NEVER" fitToWidth="true" VBox.vgrow="ALWAYS">
                     <content>
                        <VBox fx:id="historyContainer" spacing="5.0" />
                     </content>
                  </ScrollPane>

                  <VBox minHeight="90.0" prefHeight="90.0">
                     <children>
                        <Label text="Tóm tắt lịch sử"><font><Font name="System Bold" size="20.0" /></font></Label>
                        <HBox alignment="CENTER" prefHeight="100.0" spacing="30.0">
                           <children>
                              <Label contentDisplay="RIGHT" prefHeight="34.0" prefWidth="210.0"
                                     style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-radius: 10;"
                                     text="Tổng sản phẩm đã đấu giá:">
                                 <font><Font size="14.0" /></font>
                                 <effect><DropShadow offsetY="4.0" /></effect>
                                 <padding><Insets left="5.0" /></padding>
                                 <graphic><Label text="..." /></graphic>
                              </Label>
                              <Label contentDisplay="RIGHT" prefHeight="34.0" prefWidth="210.0"
                                     style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-radius: 10;"
                                     text="Sản phẩm thắng:">
                                 <font><Font size="14.0" /></font>
                                 <effect><DropShadow offsetY="4.0" /></effect>
                                 <padding><Insets left="5.0" /></padding>
                                 <graphic><Label text="..." /></graphic>
                              </Label>
                              <Label contentDisplay="RIGHT" prefHeight="34.0" prefWidth="210.0"
                                     style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-radius: 10;"
                                     text="Tỷ lệ thắng:">
                                 <font><Font size="14.0" /></font>
                                 <effect><DropShadow offsetY="4.0" /></effect>
                                 <padding><Insets left="5.0" /></padding>
                                 <graphic><Label text="...%" /></graphic>
                              </Label>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</VBox>
