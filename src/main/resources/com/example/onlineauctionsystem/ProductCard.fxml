<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<GridPane xmlns="http://javafx.com/javafx/17.0.12"
          xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="com.example.onlineauctionsystem.controller.common.ProductCardController"
          hgap="5.0" vgap="10.0"
          maxWidth="1.7976931348623157E308" minWidth="320.0"
          minHeight="130.0" prefHeight="130.0"
          style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">

    <columnConstraints>
        <ColumnConstraints hgrow="NEVER" minWidth="90.0" prefWidth="90.0" maxWidth="90.0" />
        <ColumnConstraints hgrow="ALWAYS" minWidth="120.0" prefWidth="220.0" />
        <ColumnConstraints hgrow="NEVER" minWidth="90.0" prefWidth="90.0" maxWidth="90.0" />
    </columnConstraints>
    <rowConstraints>
        <RowConstraints minHeight="110.0" prefHeight="110.0" />
    </rowConstraints>

    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>

    <StackPane style="-fx-background-radius: 15; -fx-background-color: white;
                      -fx-border-radius: 15; -fx-border-color: #e0e0e0; -fx-border-width: 1;">
        <GridPane.margin>
            <Insets bottom="2.0" left="2.0" right="2.0" top="2.0" />
        </GridPane.margin>
        <effect><DropShadow offsetY="4.0" /></effect>
        <children>
            <ImageView fx:id="imgProduct"
                       fitHeight="87.0" fitWidth="80.0"
                       pickOnBounds="true" preserveRatio="true">
                <StackPane.margin>
                    <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                </StackPane.margin>
            </ImageView>
        </children>
    </StackPane>

    <VBox GridPane.columnIndex="1" GridPane.hgrow="ALWAYS"
          maxWidth="1.7976931348623157E308" prefHeight="110.0">
        <GridPane.margin><Insets left="5.0" right="5.0" /></GridPane.margin>
        <children>
            <Label fx:id="lblName" text="---" wrapText="true"
                   maxWidth="1.7976931348623157E308">
                <font><Font size="15.0" name="System Bold" /></font>
            </Label>
            <Label fx:id="lblPrice" text="Giá khởi điểm: ---" />
            <Label fx:id="lblStatus" text="Trạng thái: ---" />
        </children>
    </VBox>

    <VBox GridPane.columnIndex="2" alignment="CENTER" spacing="8.0">
        <children>
            <Button fx:id="btnEdit"
                    mnemonicParsing="false"
                    onAction="#onEdit"
                    prefHeight="26.0" prefWidth="79.0"
                    style="-fx-background-color: white; -fx-background-radius: 15;
                           -fx-border-radius: 15;
                           -fx-border-color: linear-gradient(to bottom left, #0099cc 0%, #004488 40%, #001a33 100%);"
                    text="Chỉnh sửa" textFill="#1365a4">
                <cursor><Cursor fx:constant="HAND" /></cursor>
                <font><Font name="System Bold" size="12.0" /></font>
            </Button>
            <Button fx:id="btnDelete"
                    mnemonicParsing="false"
                    onAction="#onDelete"
                    prefHeight="26.0" prefWidth="79.0"
                    style="-fx-background-color: white; -fx-background-radius: 15;
                           -fx-border-radius: 15; -fx-border-color: #cc0000;"
                    text="Xóa" textFill="#cc0000">
                <cursor><Cursor fx:constant="HAND" /></cursor>
                <font><Font name="System Bold" size="12.0" /></font>
            </Button>
        </children>
    </VBox>

</GridPane>
